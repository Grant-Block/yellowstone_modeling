#----------------------------------------------------------------------------
# Create the domain, a block with a large ellipsoidal
# CR
#----------------------------------------------------------------------------
# create the CR ellipsoid
create vertex 0 0 0
create vertex 0 -55000 0
create vertex -32000 0 0
curve 13 copy reflect y
curve 13 copy reflect x
curve 14 copy reflect x
create surface curve 13 14 15 16
delete vertex 7
sweep surface 9 direction 0 0 1 distance -26000
# Move out of the way
volume 2 move x {CR_x_shift} y {CR_y_shift} z {3*source_depth}
create brick x {sizeX} y {sizeY} z {sizeZ}
volume 3 move x 0 y 0 z {-0.5*sizeZ}
#move volumes back and subtract
volume 2 move copy x 0 y 0 z {-3*source_depth-CR_depth/2}
subtract volume 4 from 3
volume 2 move x 0 y 0 z {-3*source_depth-CR_depth/2}
volume 1 move x 0 y 0 z {-2*source_depth}
subtract volume 1 from 2
merge all
compress all
#cut domain into layers
webcut volume 1 with plane zplane offset {-upperCrustHeight}
imprint volume 1 with volume 2
webcut volume 3 with plane zplane offset {-upperCrustHeight-lowerCrustHeight}
merge all
compress all
