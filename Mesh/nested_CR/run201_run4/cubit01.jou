body 4 copy reflect y
body 3 copy reflect y
body 5 copy reflect y
create volume surface 9 10 11 12 13 14 15 16 heal
delete vertex 7
delete curve 17
volume 9 move x {second_source_x_shift} y {second_source_y_shift} z {second_source_depth}
#----------------------------------------------------------------------------
# Create the domain, a block with a large ellipsoidal
# CR
#----------------------------------------------------------------------------
# create the CR eliptical prism
create vertex 0 0 0
create vertex 0 -55000 0
create vertex -32000 0 0
curve 38 copy reflect y
