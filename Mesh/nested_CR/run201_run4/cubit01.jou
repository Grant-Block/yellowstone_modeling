${source_y_rad=1.0*base_CR_y_rad}
${source_z_rad=1.5*km}
${second_source_x_rad=source_x_rad*(2.3**(1/3))}
${second_source_y_rad=source_y_rad*(2.3**(1/3))}
${second_source_z_rad=source_z_rad*(2.3**(1/3))}
${source_x_shift = 0.0*km}
${source_y_shift = 0.0*km}
${second_source_x_shift = -5.0*km}
${second_source_y_shift = -0.75*km}
