## Command Options:
reset
undo off
cd "/home/grantblock/Research/Yellowstone/Mesh/nested_CR/run216"
# ----------------------------------------------------------------------
# Set units to SI
# ----------------------------------------------------------------------
${Units('si')}
# ----------------------------------------------------------------------
# Set  geometry parameters
# ----------------------------------------------------------------------
${CR_depth=4.0*km}
${inner_CR_depth=6.0*km}
${source_depth=5.0*km}
${second_source_depth=24.0*km}
#source and CR parameters
${base_CR_x_rad = 13.0*km}
${base_CR_y_rad = 27.5*km}
${base_CR_z_rad = 2.5*km}
${CR_x_rad = 32.0*km}
${CR_y_rad = 55.0*km}
${CR_height = 26.0*km}
${inner_CR_x_rad = 22.0*km}
${inner_CR_y_rad = 40.0*km}
${inner_CR_height = 19.0*km}
${source_x_rad=0.5*base_CR_x_rad}
${source_y_rad=1.0*base_CR_y_rad}
${source_z_rad=1.5*km}
${second_source_x_rad=source_x_rad*(2.3**(1/3))}
${second_source_y_rad=source_y_rad*(2.3**(1/3))}
${second_source_z_rad=source_z_rad*(2.3**(1/3))}
${source_x_shift = 0.0*km}
${source_y_shift = 0.0*km}
${second_source_x_shift = -5.0*km}
${second_source_y_shift = -0.75*km}
${CR_x_shift = -5.0*km}
${CR_y_shift = -0.75*km}
# Domain size parameters
${sizeX=200.0*km}
${sizeY=200.0*km}
${sizeZ=100.0*km}
${upperCrustHeight=5*km}
${lowerCrustHeight=45*km}
${lithosphericMantleHeight=50*km}
#${asthenosphereHeight=100*km}
#------------------------------------------------------------------------
# Create ellipsoidal magma chamber
#------------------------------------------------------------------------
create vertex 0 0 0
create vertex 0 -27500 0
create vertex 0 0 -1500
create vertex -6500 0 0
curve 1 copy reflect z
curve 2 copy reflect z
create curve vertex 3 7
create surface curve 3 4 6
create surface curve 1 2 6
merge all
body 1 copy reflect x
body 2 copy reflect x
body 1 copy reflect y
body 3 copy reflect y
body 2 copy reflect y
body 4 copy reflect y
create volume surface 1 2 3 4 5 6 7 8 heal
delete vertex 1
delete curve 5
compress all
# Move out of the way
volume 1 move x {source_x_shift} y {source_y_shift} z {source_depth}
#------------------------------------------------------------------------
# Create second source
#------------------------------------------------------------------------
create vertex 0 0 0
create vertex 0 -36300.16835 0
create vertex 0 0 -1980.009183
create vertex -8580.039792 0 0
curve 13 copy reflect z
curve 14 copy reflect z
create curve vertex 9 13
create surface curve 15 16 18
create surface curve 13 14 18
merge all
body 2 copy reflect x
body 3 copy reflect x
body 2 copy reflect y
body 4 copy reflect y
body 3 copy reflect y
body 5 copy reflect y
create volume surface 9 10 11 12 13 14 15 16 heal
delete vertex 7
delete curve 17
volume 9 move x {second_source_x_shift} y {second_source_y_shift} z {second_source_depth}
#----------------------------------------------------------------------------
# Create the domain, a block with a large ellipsoidal
# CR
#----------------------------------------------------------------------------
# create the CR eliptical prism
create vertex 0 0 0
create vertex 0 -55000 0
create vertex -32000 0 0
curve 38 copy reflect y
curve 38 copy reflect x
curve 39 copy reflect x
create surface curve 38 39 40 41
delete vertex 40
sweep surface 17 direction 0 0 1 distance -26000
# Move out of the way
volume 10 move x {CR_x_shift} y {CR_y_shift} z {3*source_depth}
# create the inner CR elliptical prism
create vertex 0 0 0
create vertex 0 -40000 0
create vertex -22000 0 0
curve 50 copy reflect y
curve 50 copy reflect x
curve 51 copy reflect x
create surface curve 50 51 52 53
delete vertex 53
sweep surface 23 direction 0 0 1 distance -19000
volume 11 move x 0 y 0 z {3*source_depth}
create brick x {sizeX} y {sizeY} z {sizeZ}
volume 12 move x 0 y 0 z {-0.5*sizeZ}
#move volumes back and subtract
volume 10 move copy x 0 y 0 z {-3*source_depth-CR_depth/2}
subtract volume 13 from 12
volume 10 move x 0 y 0 z {-3*source_depth-CR_depth/2}
volume 11 move copy x 0 y 0 z {-3*source_depth-inner_CR_depth/2}
subtract volume 15 from 10
volume 11 move x 0 y 0 z {-3*source_depth-inner_CR_depth/2}
volume 1 move x 0 y 0 z {-2*source_depth}
subtract volume 1 from 11
volume 9 move x 0 y 0 z {-2*second_source_depth}
subtract volume 9 from 11
merge all
compress all
#cut domain into layers
webcut volume 1 with plane zplane offset {-upperCrustHeight}
imprint volume 1 with volume 2
webcut volume 4 with plane zplane offset {-upperCrustHeight-lowerCrustHeight}
merge all
compress all
reset
undo off
cd "/home/grantblock/Research/Yellowstone/Mesh/nested_CR/run216"
