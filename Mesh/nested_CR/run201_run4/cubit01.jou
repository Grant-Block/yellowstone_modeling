sweep surface 23 direction 0 0 1 distance -24000
volume 11 move x 0 y 0 z {3*source_depth}
create brick x {sizeX} y {sizeY} z {sizeZ}
volume 12 move x 0 y 0 z {-0.5*sizeZ}
#move volumes back and subtract
volume 10 move copy x 0 y 0 z {-3*source_depth-CR_depth/2}
subtract volume 13 from 12
volume 10 move x 0 y 0 z {-3*source_depth-CR_depth/2}
volume 11 move copy x 0 y 0 z {-3*source_depth-inner_CR_depth/2}
subtract volume 15 from 10
volume 11 move x 0 y 0 z {-3*source_depth-inner_CR_depth/2}
volume 1 move x 0 y 0 z {-2*source_depth}
subtract volume 1 from 11
volume 9 move x 0 y 0 z {-2*second_source_depth}
subtract volume 9 from 11
merge all
compress all
#cut domain into layers
webcut volume 1 with plane zplane offset {-upperCrustHeight}
imprint volume 1 with volume 2
webcut volume 4 with plane zplane offset {-upperCrustHeight-lowerCrustHeight}
merge all
compress all
#define cell sizes
${maxCellSize=20.0*km}
${minCellSize=1.0*km}
${midCellSize=4.0*km}
${CRCellSize=5.0*km}
${CRCellSizeLarge=10.0*km}
# ----------------------------------------------------------------------
# Create tet4 mesh with resolution dictated by 'cell_size_fn'.
# ----------------------------------------------------------------------
volume all scheme tetmesh
import sizing function "temp_mesh.exo" block all variable "cell_size_fn" time 0
surface 1 size {CRCellSizeLarge}
surface 2 size {CRCellSize}
surface 3 size {CRCellSize}
surface 4 size {CRCellSize}
surface 5 size {CRCellSize}
surface 6 size {CRCellSize}
surface 7 size {CRCellSize}
surface 8 size {CRCellSize}
surface 9 sizing function type exodus
surface 10 size {maxCellSize}
surface 11 size {minCellSize}
surface 12 size {minCellSize}
surface 13 size {minCellSize}
surface 14 size {minCellSize}
surface 15 size {minCellSize}
surface 16 size {minCellSize}
surface 17 size {minCellSize}
surface 18 size {minCellSize}
surface 19 size {midCellSize}
surface 20 size {midCellSize}
surface 21 size {midCellSize}
surface 22 size {midCellSize}
surface 23 size {midCellSize}
surface 24 size {midCellSize}
surface 25 size {midCellSize}
surface 26 size {midCellSize}
surface 27 sizing function type exodus
surface 28 size {CRCellSizeLarge}
surface 29 size {CRCellSizeLarge}
surface 30 size {CRCellSizeLarge}
surface 31 size {CRCellSizeLarge}
surface 32 size {maxCellSize}
surface 33 size {maxCellSize}
surface 34 size {maxCellSize}
surface 35 size {maxCellSize}
surface 36 size {CRCellSizeLarge}
surface 37 size {CRCellSizeLarge}
surface 38 size {CRCellSizeLarge}
surface 39 size {CRCellSizeLarge}
surface 41 size {maxCellSize}
surface 42 size {maxCellSize}
surface 43 size {maxCellSize}
surface 44 size {maxCellSize}
surface 45 size {maxCellSize}
surface 46 size {maxCellSize}
surface 47 size {maxCellSize}
surface 48 size {maxCellSize}
# ----------------------------------------------------------------------
# Generate the mesh
# ----------------------------------------------------------------------
mesh surface all
mesh volume all
# ----------------------------------------------------------------------
# Smooth mesh to improve quality
# ----------------------------------------------------------------------
volume all smooth scheme condition number beta 1.8 cpu 10
surface all smooth scheme condition number beta 1.8 cpu 10
smooth volume all
# ----------------------------------------------------------------------------------------------
# Create Boundary Conditions
#----------------------------------------------------------------------------------------------
#Create blocks for materials
block 1 volume 1
block 1 name "upperCrust"
block 2 volume 4
block 2 name "lowerCrust"
block 3 volume 3
block 3 name "viscoelasticCylinder"
block 4 volume 5
block 4 name "lithosphericMantle"
block 5 volume 2
block 5 name "outerCR"
merge all
compress all
# Chamber nodesets
group "chamber_top" add node in surface 11 13 15 16
nodeset 1 chamber_top
nodeset 1 name "chamber_top"
group "chamber_bot" add node in surface 12 14 17 18
nodeset 2 chamber_bot
nodeset 2 name "chamber_bot"
group "second_chamber_top" add node in surface 19 21 23 24
nodeset 9 second_chamber_top
nodeset 9 name "second_chamber_top"
group "second_chamber_bot" add node in surface 20 22 25 26
nodeset 10 second_chamber_bot
nodeset 10 name "second_chamber_bot"
# +x face nodeset
group "face_xpos" add node in surface 35 43 46
nodeset 3 face_xpos
nodeset 3 name "face_xpos"
# -x face nodeset
group "face_xneg" add node in surface 33 41 48
nodeset 4 face_xneg
nodeset 4 name "face_xneg"
# +y face nodeset
group "face_ypos" add node in surface 32 44 45
nodeset 5 face_ypos
nodeset 5 name "face_ypos"
# -y face nodeset
group "face_yneg" add node in surface 34 42 47
nodeset 6 face_yneg
nodeset 6 name "face_yneg"
# +z face nodeset
group "face_zpos" add node in surface 9
nodeset 7 face_zpos
nodeset 7 name "face_zpos"
# -z face nodeset
group "face_zneg" add node in surface 10
nodeset 8 face_zneg
nodeset 8 name "face_zneg"
export mesh "run216.exo" dimension 3 overwrite
reset
undo off
cd "/home/grantblock/Research/Yellowstone/Mesh/uniform_CR/run0"
# ----------------------------------------------------------------------
# Set units to SI
# ----------------------------------------------------------------------
${Units('si')}
# ----------------------------------------------------------------------
# Set  geometry parameters
# ----------------------------------------------------------------------
${CR_depth=6.5*km}
${source_depth=6.5*km}
#source and CR parameters
${CR_x_rad = 13.0*km}
${CR_y_rad = 27.5*km}
${CR_z_rad = 2.5*km}
${source_x_rad=0.5*CR_x_rad}
${source_y_rad=0.5*CR_y_rad}
${source_z_rad=0.5*CR_z_rad}
# Domain size parameters
${sizeX=300.0*km}
${sizeY=300.0*km}
${sizeZ=200.0*km}
${upperCrustHeight=10*km}
${lowerCrustHeight=20*km}
${lithosphericMantleHeight=70*km}
${asthenosphereHeight=100*km}
#------------------------------------------------------------------------
# Create ellipsoidal magma chamber
#------------------------------------------------------------------------
create vertex 0 0 0
create vertex 0 -13750 0
create vertex 0 0 -1250
create vertex -6500 0 0
curve 1 copy reflect z
curve 2 copy reflect z
create curve vertex 3 7
create surface curve 3 4 6
create surface curve 1 2 6
merge all
body 1 copy reflect x
body 2 copy reflect x
body 1 copy reflect y
body 3 copy reflect y
body 2 copy reflect y
body 4 copy reflect y
create volume surface 1 2 3 4 5 6 7 8 heal
delete vertex 1
delete curve 5
compress all
# Move to the SMB depth
volume 1 move x 0 y 0 z {-source_depth}
#----------------------------------------------------------------------------
# Create the domain, a block with a large ellipsoidal
# CR
#----------------------------------------------------------------------------
# create the CR ellipsoid
create vertex 0 0 0
create vertex 0 -27500 0
create vertex 0 0 -2500
create vertex -13000 0 0
curve 13 copy reflect z
curve 14 copy reflect z
create curve vertex 9 13
create surface curve 15 16 18
create surface curve 13 14 18
merge all
body 2 copy reflect x
body 3 copy reflect x
body 2 copy reflect y
body 4 copy reflect y
body 3 copy reflect y
body 5 copy reflect y
create volume surface 9 10 11 12 13 14 15 16 heal
delete vertex 7
delete curve 17
compress all
merge all
#rotate CR for perpendicular CR mesh
#Rotate volume 2 about Z angle 90
# Move to CR depth
volume 2 move x 0 y 0 z {-CR_depth}
create brick x {sizeX} y {sizeY} z {sizeZ}
volume 3 move x 0 y 0 z {-0.5*sizeZ}
# make a hole in the domain where the CR is
subtract volume 2 from 3
# remake the CR and put it back in the hole
volume 1 move x 0 y 0 z {-5*sizeZ}
volume 4 move x 0 y 0 z {-5*sizeZ}
create vertex 0 0 0
create vertex 0 -27500 0
create vertex 0 0 -2500
create vertex -13000 0 0
curve 49 copy reflect z
curve 50 copy reflect z
create curve vertex 29 33
create surface curve 51 52 54
create surface curve 49 50 54
merge all
body 4 copy reflect x
body 5 copy reflect x
body 4 copy reflect y
body 6 copy reflect y
body 5 copy reflect y
body 7 copy reflect y
create volume surface 31 32 33 34 35 36 37 38 heal
delete vertex 27
delete curve 53
compress all
merge all
#Rotate CR for perpendicular case
#Rotate volume 3 about Z angle 90
#move other volumes back
volume 1 move x 0 y 0 z {5*sizeZ}
volume 2 move x 0 y 0 z {5*sizeZ}
volume 3 move x 0 y 0 z {-CR_depth}
compress all
merge all
#cut domain into layers
webcut volume 2 with plane zplane offset {-upperCrustHeight}
webcut volume 2 with plane zplane offset {-upperCrustHeight-lowerCrustHeight}
webcut volume 5 with plane zplane offset {-upperCrustHeight-lowerCrustHeight-lithosphericMantleHeight}
compress all
merge all
#------------------------------------------------------------------------------
# Subtract the volumes to make the chamber hollow
#------------------------------------------------------------------------------
subtract volume 1 from volume 3
merge all
compress all
reset
undo off
cd "/home/grantblock/Research/Yellowstone/Mesh/uniform_CR/run0"
