## /opt/Trelis-16.1/bin/trelis
## Trelis Version 16.1.1
## Trelis Build 1b15f60
## Revised Tue Aug 23 16:17:41 2016 -0600
## Running 08/27/2025 10:46:45 AM
## Command Options:
reset
undo off
cd "/home/grantblock/Research/Yellowstone/Mesh/nested_CR/run191_run2"
# ----------------------------------------------------------------------
# Set units to SI
# ----------------------------------------------------------------------
${Units('si')}
# ----------------------------------------------------------------------
# Set  geometry parameters
# ----------------------------------------------------------------------
${CR_depth=4.0*km}
${inner_CR_depth=6.0*km}
${source_depth=5.0*km}
#source and CR parameters
${base_CR_x_rad = 13.0*km}
${base_CR_y_rad = 27.5*km}
${base_CR_z_rad = 2.5*km}
${CR_x_rad = 32.0*km}
${CR_y_rad = 55.0*km}
${CR_height = 26.0*km}
${inner_CR_x_rad = 22.0*km}
${inner_CR_y_rad = 40.0*km}
${inner_CR_height = 19.0*km}
${source_x_rad=0.5*base_CR_x_rad}
${source_y_rad=1.0*base_CR_y_rad}
${source_z_rad=1.5*km}
${source_x_shift = 0.0*km}
${source_y_shift = 0.0*km}
${CR_x_shift = -5.0*km}
${CR_y_shift = -0.75*km}
# Domain size parameters
${sizeX=300.0*km}
${sizeY=300.0*km}
${sizeZ=200.0*km}
${upperCrustHeight=5*km}
${lowerCrustHeight=44*km}
${lithosphericMantleHeight=50*km}
${asthenosphereHeight=100*km}
#------------------------------------------------------------------------
# Create ellipsoidal magma chamber
#------------------------------------------------------------------------
create vertex 0 0 0
create vertex 0 -27500 0
create vertex 0 0 -1500
create vertex -6500 0 0
curve 1 copy reflect z
curve 2 copy reflect z
create curve vertex 3 7
create surface curve 3 4 6
create surface curve 1 2 6
merge all
body 1 copy reflect x
body 2 copy reflect x
body 1 copy reflect y
body 3 copy reflect y
body 2 copy reflect y
body 4 copy reflect y
create volume surface 1 2 3 4 5 6 7 8 heal
delete vertex 1
delete curve 5
compress all
# Move out of the way
volume 1 move x {source_x_shift} y {source_y_shift} z {source_depth}
#----------------------------------------------------------------------------
# Create the domain, a block with a large ellipsoidal
# CR
#----------------------------------------------------------------------------
# create the CR eliptical prism
create vertex 0 0 0
create vertex 0 -55000 0
create vertex -32000 0 0
curve 13 copy reflect y
curve 13 copy reflect x
curve 14 copy reflect x
create surface curve 13 14 15 16
delete vertex 7
sweep surface 9 direction 0 0 1 distance -26000
# Move out of the way
volume 2 move x {CR_x_shift} y {CR_y_shift} z {3*source_depth}
# create the inner CR elliptical prism
create vertex 0 0 0
create vertex 0 -40000 0
create vertex -22000 0 0
curve 25 copy reflect y
curve 25 copy reflect x
curve 26 copy reflect x
create surface curve 25 26 27 28
delete vertex 20
sweep surface 15 direction 0 0 1 distance -19000
volume 3 move x 0 y 0 z {3*source_depth}
create brick x {sizeX} y {sizeY} z {sizeZ}
volume 4 move x 0 y 0 z {-0.5*sizeZ}
#move volumes back and subtract
volume 2 move copy x 0 y 0 z {-3*source_depth-CR_depth/2}
subtract volume 5 from 4
volume 2 move x 0 y 0 z {-3*source_depth-CR_depth/2}
volume 3 move copy x 0 y 0 z {-3*source_depth-inner_CR_depth/2}
subtract volume 7 from 2
volume 3 move x 0 y 0 z {-3*source_depth-inner_CR_depth/2}
volume 1 move x 0 y 0 z {-2*source_depth}
subtract volume 1 from 3
merge all
compress all
#cut domain into layers
webcut volume 1 with plane zplane offset {-upperCrustHeight}
imprint volume 1 with volume 2
webcut volume 4 with plane zplane offset {-upperCrustHeight-lowerCrustHeight}
webcut volume 5 with plane zplane offset {-upperCrustHeight-lowerCrustHeight-lithosphericMantleHeight}
merge all
compress all
reset
undo off
reset
undo off
cd "/home/grantblock/Research/Yellowstone/Mesh/nested_CR/run191_run2"
