# ----------------------------------------------------------------------
# Generate geometry
# ----------------------------------------------------------------------
playback 'geometry.jou'

#define cell sizes
${maxCellSize=20.0*km}
${minCellSize=1.0*km}
${midCellSize=2.5*km}
${CRCellSize=5.0*km}
# ----------------------------------------------------------------------
# Create tet4 mesh with resolution dictated by 'cell_size_fn'.
# ----------------------------------------------------------------------
volume all scheme tetmesh
import sizing function  "temp_mesh.exo" block all variable "cell_size_fn" time 0.0000000 

surface 1 size {CRCellSize}
surface 2 size {CRCellSize}

surface 3 sizing function type exodus
surface 4 size {maxCellSize}

surface 5, 6, 7, 8, 9, 10, 11, 12 size {minCellSize}

surface 13, 14, 15, 16, 17, 18, 19, 20 size {midCellSize}

surface 21 sizing function type exodus

surface 22, 23, 24, 25 size {CRCellSize}

surface 26, 27, 28, 29 size {maxCellSize}

surface 30, 31, 32, 33  size {CRCellSize}

surface 35, 36, 37, 38, 39, 40, 41, 42 size {maxCellSize}

# ----------------------------------------------------------------------
# Generate the mesh
# ----------------------------------------------------------------------
mesh surface all
mesh volume all

# ----------------------------------------------------------------------
# Smooth mesh to improve quality
# ----------------------------------------------------------------------
volume all smooth scheme condition number beta 1.8 cpu 10
surface all smooth scheme condition number beta 1.8 cpu 10

smooth volume all































