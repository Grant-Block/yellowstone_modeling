# ----------------------------------------------------------------------------------------------
# Create Boundary Conditions
#----------------------------------------------------------------------------------------------

#Create blocks for materials

block 1 volume 1
block 1 name "upperCrust"

block 2 volume 2
block 2 name "lowerCrust"

block 3 volume 3
block 3 name "lithosphericMantle"

merge all 
compress all

# Chamber nodesets

group "chamber_top" add node in surface 3 5 7 8
nodeset 1 chamber_top
nodeset 1 name "chamber_top"

group "chamber_bot" add node in surface 4 6 9 10
nodeset 2 chamber_bot
nodeset 2 name "chamber_bot"



# +x face nodeset

group "face_xpos" add node in surface 15 19 22
nodeset 3 face_xpos
nodeset 3 name "face_xpos"

# -x face nodeset

group "face_xneg" add node in surface 13 17 24
nodeset 4 face_xneg
nodeset 4 name "face_xneg"

# +y face nodeset

group "face_ypos" add node in surface 12 20 21
nodeset 5 face_ypos
nodeset 5 name "face_ypos"

# -y face nodeset

group "face_yneg" add node in surface 14 18 23
nodeset 6 face_yneg
nodeset 6 name "face_yneg"

# +z face nodeset

group "face_zpos" add node in surface 1
nodeset 7 face_zpos
nodeset 7 name "face_zpos"

# -z face nodeset

group "face_zneg" add node in surface 2
nodeset 8 face_zneg
nodeset 8 name "face_zneg"

export mesh "run206.exo" dimension 3 overwrite
























































